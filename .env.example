# =============================================================================
# AsepriteSync — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs manquantes.
# =============================================================================

# --- Base de données ---------------------------------------------------------
DATABASE_URL=postgresql://asepritesync:asepritesync@localhost:5432/asepritesync

# --- Redis -------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# --- JWT ---------------------------------------------------------------------
# Générez un secret fort : openssl rand -base64 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- CORS --------------------------------------------------------------------
CORS_ORIGIN=http://localhost:3000

# --- Upload ------------------------------------------------------------------
MAX_FILE_SIZE_MB=50
MAX_VERSIONS_PER_FILE=50

# --- Stockage ----------------------------------------------------------------
# local | s3
STORAGE_TYPE=local
STORAGE_PATH=./storage

# S3 / MinIO (utilisé si STORAGE_TYPE=s3)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=asepritesync
S3_REGION=us-east-1
S3_ACCESS_KEY=asepritesync
S3_SECRET_KEY=asepritesync_secret

# --- Verrouillage -------------------------------------------------------------
LOCK_DURATION_MINUTES=30

# --- Serveur -----------------------------------------------------------------
PORT=4000
NODE_ENV=development

# --- Email (reset mot de passe) ----------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@asepritesync.local

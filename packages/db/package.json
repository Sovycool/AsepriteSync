{
  "name": "@asepritesync/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "generate": "drizzle-kit generate",
    "migrate": "tsx -r dotenv/config src/migrate.ts dotenv_config_path=../../.env",
    "seed": "tsx -r dotenv/config src/seed.ts dotenv_config_path=../../.env",
    "studio": "drizzle-kit studio",
    "build": "tsc --project tsconfig.json",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@asepritesync/shared": "workspace:*",
    "bcrypt": "^5.1.1",
    "drizzle-orm": "^0.30.10",
    "postgres": "^3.4.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.12.0",
    "@types/uuid": "^9.0.8",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.21.4",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
